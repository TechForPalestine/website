---
// Fallback donation form for donate-new.astro (linked from there as "this form"
// when the primary embed doesn't load) — not an accidental duplicate page.
import { getEnv } from "../utils/getEnv";
import HomeLayout from "../layouts/HomeLayout.astro";
import HomeNavbar from "../components/home/HomeNavbar.astro";

const membershipLive = getEnv("MEMBERSHIP_LIVE", Astro.locals) === "true";
---

<HomeLayout
  title="Support Our Work | Tech for Palestine"
  description="Alternate donation form for Tech for Palestine. Use this page if the primary donate form doesn't load in your browser."
  noindex={true}
  canonicalUrl="https://techforpalestine.org/donate"
  organizationSchemaExtra={{
    potentialAction: {
      "@type": "DonateAction",
      name: "Donate to Tech for Palestine",
      description:
        "Your donation helps us hire professionals, strengthen existing projects, and launch new initiatives for a free Palestine.",
      target: "https://techforpalestine.org/donate",
    },
  }}
>
  <HomeNavbar membershipLive={membershipLive} alwaysVisible />

  <main class="pt-20">
    <!-- Hero -->
    <section class="bg-page px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-[1400px]">
        <div class="donate-animate max-w-[680px]">
          <p class="ts-overline mb-6 text-ink-secondary">Support Our Work</p>
          <h1 class="ts-editorial mb-6 text-ink">
            Support <span class="text-brand">Tech for Palestine</span>
          </h1>
          <p class="ts-body-large max-w-[65ch] text-ink-secondary">
            Since launching Tech for Palestine, we've helped bring impactful projects to life: Media
            Bias Meter, Boycat, Find a Protest, Newscord, and many more.
          </p>
          <p class="ts-body-large mt-4 max-w-[65ch] text-ink-secondary">
            Your donation helps us hire professionals, strengthen existing projects, and launch new
            initiatives for a free Palestine.
          </p>
        </div>

        <!-- Highlight chips -->
        <div class="donate-animate mt-10 flex flex-wrap gap-3">
          <div
            class="flex items-center gap-2 rounded-pill border border-butter bg-sand px-4 py-2.5"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 text-brand"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span class="ts-label text-ink">Hire professionals</span>
          </div>
          <div
            class="flex items-center gap-2 rounded-pill border border-butter bg-sand px-4 py-2.5"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 text-brand"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"
              ></path>
            </svg>
            <span class="ts-label text-ink">Strengthen projects</span>
          </div>
          <div
            class="flex items-center gap-2 rounded-pill border border-butter bg-sand px-4 py-2.5"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              class="h-4 w-4 text-brand"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"></path>
            </svg>
            <span class="ts-label text-ink">Launch new initiatives</span>
          </div>
        </div>
      </div>
    </section>

    <!-- Donation Form + Sidebar -->
    <section class="bg-sand px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-[1400px]">
        <div class="grid grid-cols-1 gap-8 min-[1050px]:grid-cols-3">
          <!-- Donation Card -->
          <div class="min-[1050px]:col-span-2">
            <div class="rounded-[20px] border border-butter bg-page p-6 min-[810px]:p-8">
              <h2 class="ts-heading mb-6 text-ink">Make a donation</h2>
              <div class="w-full">
                <div
                  data-entity="EMBED_FORM"
                  data-source="CharityStack"
                  id="1546c2c2-a580-4994-bbb3-9e643aed1309"
                >
                </div>
              </div>

              <!-- Trust badges -->
              <div class="mt-6 flex flex-wrap items-center gap-4 border-t border-ink-divider pt-5">
                <div class="flex items-center gap-2">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    class="h-4 w-4 text-brand"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                  </svg>
                  <span class="ts-body-small text-ink-secondary">501(c)(3) nonprofit</span>
                </div>
                <span class="ts-body-small text-ink-muted" aria-hidden="true">·</span>
                <span class="ts-body-small text-ink-secondary">Tax-deductible in the U.S.</span>
                <span class="ts-body-small text-ink-muted" aria-hidden="true">·</span>
                <span class="ts-body-small text-ink-secondary">EIN: 99-3441367</span>
              </div>
            </div>
          </div>

          <!-- Sidebar -->
          <div class="space-y-6">
            <!-- Why it matters -->
            <div class="rounded-[20px] border border-butter bg-cream p-6">
              <h3 class="ts-subheading mb-5 text-ink">Why your donation matters</h3>
              <ul class="space-y-4">
                <li class="flex items-baseline gap-3">
                  <span
                    class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-brand"
                    aria-hidden="true"></span>
                  <span class="ts-body text-ink-secondary"
                    >Accelerates projects already making impact</span
                  >
                </li>
                <li class="flex items-baseline gap-3">
                  <span
                    class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-brand"
                    aria-hidden="true"></span>
                  <span class="ts-body text-ink-secondary"
                    >Funds critical skills: engineering, design, marketing</span
                  >
                </li>
                <li class="flex items-baseline gap-3">
                  <span
                    class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-brand"
                    aria-hidden="true"></span>
                  <span class="ts-body text-ink-secondary"
                    >Helps launch new initiatives quickly and effectively</span
                  >
                </li>
              </ul>
            </div>

            <!-- Alternative ways to give -->
            <div class="rounded-[20px] border border-butter bg-cream p-6">
              <h3 class="ts-subheading mb-4 text-ink">Alternative ways to give</h3>
              <p class="ts-body text-ink-secondary">
                Donate through a Donor-Advised Fund (DAF), family trust, or other structured giving
                methods.
              </p>
              <p class="ts-body mt-3 text-ink-secondary">
                Email <a
                  href="mailto:donations@techforpalestine.org"
                  class="text-brand underline hover:text-brand-hover"
                  >donations&#64;techforpalestine.org</a
                > and we'll assist you.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</HomeLayout>

<style>
  .donate-animate {
    opacity: 0;
    translate: 0 20px;
    transition:
      opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1),
      translate 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .donate-animate.in-view {
    opacity: 1;
    translate: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .donate-animate {
      opacity: 1;
      translate: none;
      transition: none;
    }
  }
</style>

<script>
  const obs = new IntersectionObserver(
    (entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          e.target.classList.add("in-view");
          obs.unobserve(e.target);
        }
      });
    },
    { threshold: 0.1 }
  );
  document.querySelectorAll<HTMLElement>(".donate-animate").forEach((el) => obs.observe(el));
</script>

<script>
  document.addEventListener("DOMContentLoaded", function () {
    if (typeof (window as any).plausible !== "undefined") {
      (window as any).plausible("Donate Form", { props: { donate_form_variant: "charitystack" } });
    }

    const script = document.createElement("script");
    script.defer = true;
    script.id = "charitystack-embed";
    script.dataset.id = "M_lDGj72xT61";
    (script as HTMLScriptElement).src =
      "https://prod-donation-elements-b-donationelementsjsfilesb-1m4f4dl6p6b21.s3.us-east-2.amazonaws.com/bundle.js";
    document.body.appendChild(script);
  });
</script>
