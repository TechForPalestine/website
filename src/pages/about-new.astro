---
import { getEnv } from "../utils/getEnv";
import HomeLayout from "../layouts/HomeLayout.astro";
import HomeNavbar from "../components/home/HomeNavbar.astro";
import Button from "../components/ui/Button.astro";
import SignUpForm from "../structures/SignUpForm.astro";

const membershipLive = getEnv("MEMBERSHIP_LIVE", Astro.locals) === "true";
---

<HomeLayout
  title="About | Tech for Palestine"
  description="Tech for Palestine is a 501(c)(3) nonprofit that incubates and scales tech and advocacy projects for Palestinian liberation."
  noindex={true}
>
  <HomeNavbar membershipLive={membershipLive} alwaysVisible />
  <main class="pt-20">
    <!-- Hero -->
    <section class="bg-page px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-[1400px]">
        <div
          class="grid grid-cols-1 items-center gap-12 min-[810px]:grid-cols-2 min-[810px]:gap-16"
        >
          <!-- Text column -->
          <div class="about-animate">
            <p class="ts-overline mb-6 text-ink-secondary">About Tech for Palestine</p>
            <h1 class="ts-editorial mb-6 text-ink">
              Let's make tech a driving force for Palestinian <span class="text-brand"
                >freedom and liberation</span
              >
            </h1>
            <p class="ts-body-large mb-4 max-w-[65ch] text-ink-secondary">
              Technology should disrupt the status quo — not serve it.
            </p>
            <p class="ts-body-large mb-4 max-w-[65ch] text-ink-secondary">
              For decades, the narrative about Palestine has been shaped by selective historical
              accounts and an occupying force that restricts access to the reality on the ground.
            </p>
            <p class="ts-body-large mb-10 max-w-[65ch] text-ink-secondary">
              The community at Tech for Palestine is shifting the conversation towards equality and
              justice, by cultivating a garden of projects and services that shut down genocidal
              speech, enable people to speak up for Palestinian freedom, scale Palestinian activism
              with technology, and cultivate fierce advocates for Palestine within the Tech
              community.
            </p>
            <div class="flex flex-wrap gap-4">
              <Button href="/project" variant="primary" size="md" arrow> Explore Projects </Button>
              <Button href="/get-involved-new" variant="ghost" size="md" arrow>
                Get Involved
              </Button>
              <Button href="/discord-invite" variant="ghost" size="md" arrow> Join Discord </Button>
            </div>
          </div>

          <!-- Photo gallery column -->
          <div
            class="about-animate flex justify-center gap-4 min-[810px]:justify-end min-[810px]:gap-6"
          >
            <div
              class="hidden w-36 flex-none space-y-4 pt-24 sm:w-44 sm:space-y-6 sm:pt-32 min-[1050px]:block"
            >
              <div class="overflow-hidden rounded-lg">
                <img
                  src="/protest-dc.jpg"
                  alt="Palestine solidarity march in Washington DC with demonstrators carrying Palestinian flags near Capitol building"
                  class="aspect-[2/3] w-full object-cover"
                  width="176"
                  height="264"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
            <div
              class="w-[42vw] max-w-[144px] flex-none space-y-4 min-[810px]:w-44 min-[810px]:space-y-6 min-[810px]:pt-20"
            >
              <div class="overflow-hidden rounded-lg">
                <img
                  src="/gaza-sky-geeks.webp"
                  alt="A woman working on a laptop at Gaza Sky Geeks technology center"
                  class="aspect-[2/3] w-full object-cover"
                  width="176"
                  height="264"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="overflow-hidden rounded-lg">
                <img
                  src="/jerusalem.jpg"
                  alt="Dome of the Rock in Jerusalem, Palestine, silhouetted against dramatic sunset sky with orange and purple clouds"
                  class="aspect-[2/3] w-full object-cover"
                  width="176"
                  height="264"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
            <div
              class="w-[42vw] max-w-[144px] flex-none space-y-4 pt-8 min-[810px]:w-44 min-[810px]:space-y-6 min-[810px]:pt-12"
            >
              <div class="overflow-hidden rounded-lg">
                <img
                  src="/olive-branch-thobe.jpg"
                  alt="Woman in traditional Palestinian embroidered thobe holding an olive branch, wearing ornate gold coin headpiece against olive tree background"
                  class="aspect-[2/3] w-full object-cover"
                  width="176"
                  height="264"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="overflow-hidden rounded-lg">
                <img
                  src="/gaza-father-child.avif"
                  alt="Silhouette of a Palestinian father playfully tossing child in the air against Gaza cityscape at sunset with vibrant orange and purple sky"
                  class="aspect-[2/3] w-full object-cover"
                  width="176"
                  height="264"
                  loading="lazy"
                  decoding="async"
                />
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Our Founder -->
    <section class="bg-sand px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-[1400px]">
        <div
          class="about-animate grid grid-cols-1 items-start gap-10 min-[810px]:grid-cols-[1fr_280px] min-[810px]:gap-16"
        >
          <div>
            <p class="ts-overline mb-4 text-ink-secondary">Founder</p>
            <h2 class="ts-heading mb-6 text-ink">Our Founder</h2>
            <p class="ts-body-large max-w-[75ch] text-ink-secondary">
              Paul Biggar is a tech founder and software engineer. He founded Tech For Palestine,
              <a
                href="https://circleci.com"
                class="text-brand hover:underline"
                target="_blank"
                rel="noopener noreferrer">CircleCI</a
              > and
              <a
                href="https://darklang.com"
                class="text-brand hover:underline"
                target="_blank"
                rel="noopener noreferrer">Darklang</a
              >.
            </p>
            <p class="ts-body-large mt-4 max-w-[75ch] text-ink-secondary">
              Read why <a
                href="https://blog.paulbiggar.com/i-cant-sleep/"
                class="text-brand hover:underline"
                target="_blank"
                rel="noopener noreferrer">Paul couldn't sleep</a
              > — the post that started Tech for Palestine.
            </p>
          </div>
          <div class="hidden min-[810px]:block">
            <img
              src="/images/new-homepage/why/paul.webp"
              alt="Paul Biggar, founder of Tech for Palestine"
              class="w-full rounded-[20px] border border-butter object-cover"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    <!-- What we do -->
    <section class="bg-page px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-[1400px]">
        <div class="about-animate">
          <p class="ts-overline mb-4 text-ink-secondary">Our mission</p>
          <h2 class="ts-heading mb-6 text-ink">What we do</h2>
          <p class="ts-body-large mb-6 max-w-[75ch] text-ink-secondary">
            We empower a global community of skilled tech professionals to unite in their unwavering
            support of Palestine so that we can:
          </p>
          <ul class="max-w-[75ch] space-y-3">
            <li class="ts-body-large flex items-baseline gap-3 text-ink-secondary">
              <span class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"
              ></span>
              Disrupt conventional narratives
            </li>
            <li class="ts-body-large flex items-baseline gap-3 text-ink-secondary">
              <span class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"
              ></span>
              Capture systems of power
            </li>
            <li class="ts-body-large flex items-baseline gap-3 text-ink-secondary">
              <span class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"
              ></span>
              Accelerate pro-Palestinian organizing and public awareness efforts, both online and off
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- What we want -->
    <section class="bg-sand px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-[1400px]">
        <div class="about-animate">
          <p class="ts-overline mb-4 text-ink-secondary">Our vision</p>
          <h2 class="ts-heading mb-6 text-ink">What we want</h2>
          <ul class="max-w-[75ch] space-y-6">
            <li class="ts-body-large flex items-baseline gap-3 text-ink-secondary">
              <span class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"
              ></span>
              <span
                ><span class="font-medium text-ink">A more ethical tech industry</span> that works to
                abolish the conditions for authoritarianism, surveillance, occupation, and apartheid
                in favor of those that promote justice, equality, and human rights.</span
              >
            </li>
            <li class="ts-body-large flex items-baseline gap-3 text-ink-secondary">
              <span class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"
              ></span>
              <span
                ><span class="font-medium text-ink"
                  >To draw on decades of pro-Palestinian advocacy</span
                > while building the T4P community. We humbly learn from the wider community and contribute
                to it in aim of the main goal of liberation for Palestine.</span
              >
            </li>
            <li class="ts-body-large flex items-baseline gap-3 text-ink-secondary">
              <span class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"
              ></span>
              <span
                ><span class="font-medium text-ink">To be a catalyst</span> for the reformed tech industry,
                aimed at abolishing apartheid and promoting human empowerment and development.</span
              >
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- How we work -->
    <section class="bg-page px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-[1400px]">
        <div class="about-animate">
          <p class="ts-overline mb-4 text-ink-secondary">Our approach</p>
          <h2 class="ts-heading mb-6 text-ink">How we work</h2>
          <ul class="mb-10 max-w-[75ch] space-y-3">
            <li class="ts-body-large flex items-baseline gap-3 text-ink-secondary">
              <span class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"
              ></span>
              We connect project leaders to communities of volunteers
            </li>
            <li class="ts-body-large flex items-baseline gap-3 text-ink-secondary">
              <span class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"
              ></span>
              We mentor, provide office hours, and support start-up projects aimed at ending apartheid,
              minimizing media bias, encouraging boycotts, and more
            </li>
            <li class="ts-body-large flex items-baseline gap-3 text-ink-secondary">
              <span class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"
              ></span>
              We create a community of pro-Palestinian techies to get involved in causes they believe
              in and help Palestinians get hired
            </li>
          </ul>
          <Button href="/projects-new" variant="primary" size="md" arrow>
            Learn more about our Projects
          </Button>
        </div>
      </div>
    </section>
    <!-- Full-width image -->
    <div class="px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-[1400px]">
        <img
          src="/gaza-children-playing-ocean.jpg"
          alt="Palestinian children playing joyfully in ocean waves at sunset on Gaza's Mediterranean coastline"
          class="aspect-[5/2] w-full rounded-lg object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

    <!-- Sign-up form -->
    <section class="bg-sand px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-screen-md">
        <SignUpForm />
      </div>
    </section>
  </main>
</HomeLayout>

<style>
  .about-animate {
    opacity: 0;
    transform: translateY(12px);
  }
  .about-animate.visible {
    animation: fadeUp 0.6s cubic-bezier(0.25, 1, 0.5, 1) both;
  }
  :global(html.no-js) .about-animate {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .about-animate {
      opacity: 1;
      transform: none;
    }
    .about-animate.visible {
      animation: none;
    }
  }
</style>

<script>
  const sections = document.querySelectorAll<HTMLElement>(".about-animate");
  if (sections.length > 0 && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 }
    );
    sections.forEach((el) => observer.observe(el));
  } else {
    sections.forEach((el) => {
      el.classList.add("visible");
    });
  }
</script>
