---
import Layout from "../layouts/Layout.astro";
import PageHeader from "../components/PageHeader.astro";
import MembershipPage from "../components/MembershipPage.tsx";
import "../styles/base.css";
---

<Layout
  title="Membership - Tech for Palestine"
  description="Join the coalition working on impactful initiatives for Palestinian liberation. Browse activism initiatives looking for your skills, or start an initiative of your own with T4P support."
>
  <main>
    <PageHeader
      overline="Tech for Palestine"
      title="Membership"
      subtitle="Join our coalition working for Palestinian liberation."
    />

    <!-- Hero banner -->
    <div class="h-[420px] w-full overflow-hidden">
      <img
        src="/images/membership-hero.jpg"
        alt="Tech for Palestine community members applauding at an event"
        class="h-full w-full object-cover [object-position:center_30%]"
      />
    </div>

    <div class="mx-auto max-w-4xl px-6 pb-24 pt-12 sm:px-8">
      <MembershipPage client:only="react" />
    </div>
  </main>
</Layout>
