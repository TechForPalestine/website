---
import { getEnv } from "../utils/getEnv";
import { Icon } from "astro-icon/components";
import HomeLayout from "../layouts/HomeLayout.astro";
import HomeNavbar from "../components/home/HomeNavbar.astro";
import Button from "../components/ui/Button.astro";
import SignUpForm from "../structures/SignUpForm.astro";

const membershipLive = getEnv("MEMBERSHIP_LIVE", Astro.locals) === "true";

const howToSchema = {
  "@context": "https://schema.org",
  "@type": "HowTo",
  name: "How to apply to the Tech for Palestine Incubator",
  step: [
    {
      "@type": "HowToStep",
      position: 1,
      name: "Application form",
      text: "Fill out the application (takes 10 to 30 minutes).",
    },
    {
      "@type": "HowToStep",
      position: 2,
      name: "Review",
      text: "We review your application and invite selected projects for an interview. We may reach out for more information.",
    },
    {
      "@type": "HowToStep",
      position: 3,
      name: "Interview",
      text: "A 30-minute call focusing on the impact you intend to have and how you plan to get there. No slides needed. Interviews are very direct and aim to push you on your understanding of the problem and the impact you might have.",
    },
    {
      "@type": "HowToStep",
      position: 4,
      name: "Decision",
      text: "We aim to notify all applicants within 10 days of application. Interviews and decisions happen twice weekly. In some cases we may ask more questions after the interview.",
    },
    {
      "@type": "HowToStep",
      position: 5,
      name: "Onboarding",
      text: "If admitted, you receive next steps and access to all Tech for Palestine resources.",
    },
  ],
};
---

<HomeLayout
  title="T4P Incubator | Tech for Palestine"
  description="The Tech for Palestine Incubator supports early-stage advocacy projects with mentorship, volunteers, and funding for Palestinian liberation."
  noindex={true}
>
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
  </Fragment>
  <HomeNavbar membershipLive={membershipLive} alwaysVisible />
  <main class="pt-20">
    <!-- Hero -->
    <section class="bg-page px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-[1400px]">
        <div class="incubator-animate max-w-[65ch]">
          <p class="ts-overline mb-6 text-ink-secondary">T4P Incubator</p>
          <h1 class="ts-editorial mb-6 text-ink">
            Turn your idea for Palestine into something that <span class="text-brand">scales</span>
          </h1>
          <p class="ts-body-large mb-4 max-w-[60ch] text-ink-secondary">
            The Tech for Palestine incubator supports initiatives for Palestine, by getting them off
            the ground and helping them scale up. Our goal is to create a broad and diverse set of
            initiatives for Palestine that are able to educate the entire world about Palestine, and
            to address Hasbara and Zionism wherever it takes hold.
          </p>
          <p class="ts-body-large mb-10 max-w-[60ch] text-ink-secondary">
            We take on a limited number of projects to support with our expertise and resources.
          </p>
          <div class="flex flex-wrap gap-4">
            <Button href="/project-application-form" variant="primary" size="md" arrow>
              Apply to the incubator
            </Button>
            <Button href="/ideas-new" variant="ghost" size="md" arrow>
              Browse project ideas
            </Button>
          </div>
        </div>
      </div>
    </section>

    <!-- Theory of change -->
    <section class="bg-sand px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-[1400px]">
        <div class="incubator-animate">
          <p class="ts-overline mb-4 text-ink-secondary">Why we exist</p>
          <h2 class="ts-heading mb-6 text-ink">Our theory of change</h2>
          <p class="ts-body-large max-w-[75ch] text-ink-secondary">
            Thousands of high-impact, pro-Palestinian advocacy projects are needed to counter the
            massive flood of anti-Palestinian propaganda, especially in the west. We started a
            project incubator because we saw highly motivated people with great ideas struggling to
            bring them to life. Our purpose is to provide the support, expertise, and connections
            that turn good ideas into projects with real reach.
          </p>
        </div>
      </div>
    </section>

    <!-- What you get -->
    <section class="bg-page px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-[1400px]">
        <div class="incubator-animate">
          <p class="ts-overline mb-4 text-ink-secondary">What you get</p>
          <h2 class="ts-heading mb-6 text-ink">What the incubator provides</h2>
          <ul class="grid grid-cols-1 gap-x-12 gap-y-4 min-[810px]:grid-cols-2">
            <li class="ts-body-large flex items-start gap-3 text-ink-secondary">
              <Icon
                name="mdi:lightbulb-outline"
                class="mt-1 h-5 w-5 shrink-0 text-brand"
                aria-hidden="true"
              />
              <span
                ><span class="font-medium text-ink">Strategic advice</span> from experience across 200+
                projects, starting with a strategy session to hone your approach</span
              >
            </li>
            <li class="ts-body-large flex items-start gap-3 text-ink-secondary">
              <Icon
                name="mdi:account-voice"
                class="mt-1 h-5 w-5 shrink-0 text-brand"
                aria-hidden="true"
              />
              <span
                ><span class="font-medium text-ink">Mentorship</span> through office hours 6x/week with
                Paul Biggar, plus optional dedicated weekly mentor sessions</span
              >
            </li>
            <li class="ts-body-large flex items-start gap-3 text-ink-secondary">
              <Icon
                name="mdi:hand-heart-outline"
                class="mt-1 h-5 w-5 shrink-0 text-brand"
                aria-hidden="true"
              />
              <span
                ><span class="font-medium text-ink">Volunteering</span> with access to 3,000+ registered
                volunteers and a dedicated recruitment team</span
              >
            </li>
            <li class="ts-body-large flex items-start gap-3 text-ink-secondary">
              <Icon
                name="mdi:bullhorn-outline"
                class="mt-1 h-5 w-5 shrink-0 text-brand"
                aria-hidden="true"
              />
              <span
                ><span class="font-medium text-ink">Marketing</span> to get early users through press,
                influencers, ecosystem partners, and our community</span
              >
            </li>
            <li class="ts-body-large flex items-start gap-3 text-ink-secondary">
              <Icon
                name="mdi:link-variant"
                class="mt-1 h-5 w-5 shrink-0 text-brand"
                aria-hidden="true"
              />
              <span
                ><span class="font-medium text-ink">Connections</span> to the Palestine advocacy ecosystem
                and the right partners for your initiative</span
              >
            </li>
            <li class="ts-body-large flex items-start gap-3 text-ink-secondary">
              <Icon
                name="mdi:currency-usd"
                class="mt-1 h-5 w-5 shrink-0 text-brand"
                aria-hidden="true"
              />
              <span
                ><span class="font-medium text-ink">Funding</span> through small grants to most projects,
                with minimal fuss</span
              >
            </li>
            <li class="ts-body-large flex items-start gap-3 text-ink-secondary">
              <Icon
                name="mdi:account-group-outline"
                class="mt-1 h-5 w-5 shrink-0 text-brand"
                aria-hidden="true"
              />
              <span
                ><span class="font-medium text-ink">Community</span> of 60+ project leaders facing similar
                challenges and providing mutual support</span
              >
            </li>
            <li class="ts-body-large flex items-start gap-3 text-ink-secondary">
              <Icon
                name="mdi:school-outline"
                class="mt-1 h-5 w-5 shrink-0 text-brand"
                aria-hidden="true"
              />
              <span
                ><span class="font-medium text-ink">Education</span> through seminars on marketing, sales,
                go-to-market strategy, technical projects, and T4P branding</span
              >
            </li>
          </ul>
        </div>
      </div>
    </section>

    <!-- Who it's for -->
    <section class="bg-sand px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-[1400px]">
        <div class="incubator-animate">
          <p class="ts-overline mb-4 text-ink-secondary">Who it's for</p>
          <h2 class="ts-heading mb-6 text-ink">Who the incubator is for</h2>
          <p class="ts-body-large max-w-[75ch] text-ink-secondary">
            Any early-stage project that directly or indirectly advocates for Palestine, where we
            believe you can have impact and scale. Our projects often work on <span
              class="font-medium text-ink">scaling boycotts</span
            >, <span class="font-medium text-ink">protest tech</span>, <span
              class="font-medium text-ink">tech industry divestment</span
            >, <span class="font-medium text-ink">media bias</span>, <span
              class="font-medium text-ink">reaching new audiences</span
            >, <span class="font-medium text-ink">Silicon Valley partnerships</span>, <span
              class="font-medium text-ink">AI bias</span
            >, and <span class="font-medium text-ink">exposing hasbara</span>.
          </p>
          <p class="ts-body-large mt-4 max-w-[75ch] text-ink-secondary">
            Whether you're just getting started or have an experienced team looking for connections
            and strategic advice, the incubator is built to meet you where you are.
          </p>
        </div>
      </div>
    </section>

    <!-- How the Incubator can help you -->
    <section class="bg-page px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-[1400px]">
        <div class="incubator-animate">
          <p class="ts-overline mb-4 text-ink-secondary">How we help</p>
          <h2 class="ts-heading mb-6 text-ink">How the Incubator can help you</h2>
          <div class="max-w-[75ch] space-y-5">
            <p class="ts-body-large text-ink-secondary">
              Many projects for Palestine are started by advocates who have a good idea, but don't
              yet know how to execute on it. We help support you on your journey, using our
              knowledge of building scalable projects, working with volunteers, the pro-Palestine
              ecosystem, and using our platform and network to support your work.
            </p>
            <p class="ts-body-large text-ink-secondary">
              More experienced teams may find our connections and platform valuable, as well as our
              strategic advice on how to tailor what you're building for the right niche to start,
              and our knowledge of what exists already in the ecosystem, and how to partner with
              them.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- Image break -->
    <div class="px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-[1400px]">
        <img
          src="/happy-kids.jpg"
          alt="Palestinian children smiling together"
          class="aspect-[5/2] w-full rounded-lg object-cover"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>

    <!-- What we expect -->
    <section class="bg-page px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-[1400px]">
        <div class="incubator-animate">
          <p class="ts-overline mb-4 text-ink-secondary">Our expectations</p>
          <h2 class="ts-heading mb-6 text-ink">What we expect</h2>
          <ul class="max-w-[75ch] space-y-4">
            <li class="ts-body-large flex items-baseline gap-3 text-ink-secondary">
              <span class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"
              ></span>
              <span
                ><span class="font-medium text-ink">Focus on impact</span>, such as reaching 10
                million users</span
              >
            </li>
            <li class="ts-body-large flex items-baseline gap-3 text-ink-secondary">
              <span class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"
              ></span>
              <span
                ><span class="font-medium text-ink">Commitment</span> to keep working on your project
                and driving it forward</span
              >
            </li>
            <li class="ts-body-large flex items-baseline gap-3 text-ink-secondary">
              <span class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"
              ></span>
              <span
                ><span class="font-medium text-ink">Communication</span> through office hours (weekly
                for the first 6 weeks, monthly after) and regular updates</span
              >
            </li>
            <li class="ts-body-large flex items-baseline gap-3 text-ink-secondary">
              <span class="mt-2 block h-1.5 w-1.5 shrink-0 rounded-full bg-brand" aria-hidden="true"
              ></span>
              <span
                ><span class="font-medium text-ink">Flexible participation</span>: if the incubator
                no longer fits your needs, membership may be removed without hard feelings</span
              >
            </li>
          </ul>
          <div class="mt-8">
            <p class="ts-overline mb-4 text-ink-secondary">What we don't require or expect</p>
            <ul class="grid grid-cols-1 gap-4 min-[810px]:grid-cols-3">
              <li class="rounded-lg border border-ink-divider bg-sand px-5 py-4">
                <p class="ts-label mb-1 font-medium text-ink">No Daily Meetings</p>
                <p class="ts-body text-ink-secondary">
                  We don't require daily or recurring meetings. Engage through office hours on your
                  own schedule.
                </p>
              </li>
              <li class="rounded-lg border border-ink-divider bg-sand px-5 py-4">
                <p class="ts-label mb-1 font-medium text-ink">No T4P Ownership</p>
                <p class="ts-body text-ink-secondary">
                  Your project remains yours. We don't take ownership of your work or require T4P
                  branding.
                </p>
              </li>
              <li class="rounded-lg border border-ink-divider bg-sand px-5 py-4">
                <p class="ts-label mb-1 font-medium text-ink">Flexible Tools</p>
                <p class="ts-body text-ink-secondary">
                  Use whatever tools work best for your project. We don't require specific platforms
                  or workflows.
                </p>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- How to apply -->
    <section class="bg-sand px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-[1400px]">
        <div class="incubator-animate">
          <p class="ts-overline mb-4 text-ink-secondary">The process</p>
          <h2 class="ts-heading mb-6 text-ink">How to apply</h2>
          <ol class="max-w-[75ch] list-none space-y-4">
            <li class="ts-body-large flex items-baseline gap-4 text-ink-secondary">
              <span class="ts-label shrink-0 text-brand">1</span>
              <span
                ><span class="font-medium text-ink">Application form</span>: fill out the
                application (takes 10 to 30 minutes)</span
              >
            </li>
            <li class="ts-body-large flex items-baseline gap-4 text-ink-secondary">
              <span class="ts-label shrink-0 text-brand">2</span>
              <span
                ><span class="font-medium text-ink">Review</span>: we review your application and
                invite selected projects for an interview. We may reach out for more information.</span
              >
            </li>
            <li class="ts-body-large flex items-baseline gap-4 text-ink-secondary">
              <span class="ts-label shrink-0 text-brand">3</span>
              <span
                ><span class="font-medium text-ink">Interview</span>: a 30-minute call focusing on
                the impact you intend to have and how you plan to get there. No slides needed.
                Interviews are very direct and aim to push you on your understanding of the problem
                and the impact you might have.</span
              >
            </li>
            <li class="ts-body-large flex items-baseline gap-4 text-ink-secondary">
              <span class="ts-label shrink-0 text-brand">4</span>
              <span
                ><span class="font-medium text-ink">Decision</span>: we aim to notify all applicants
                within 10 days of application. Interviews and decisions happen twice weekly. In some
                cases we may ask more questions after the interview.</span
              >
            </li>
            <li class="ts-body-large flex items-baseline gap-4 text-ink-secondary">
              <span class="ts-label shrink-0 text-brand">5</span>
              <span
                ><span class="font-medium text-ink">Onboarding</span>: if admitted, you receive next
                steps and access to all Tech for Palestine resources.</span
              >
            </li>
          </ol>
        </div>
      </div>
    </section>

    <!-- Three paths CTA -->
    <section class="bg-page px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-[1400px]">
        <div class="incubator-animate">
          <h2 class="ts-heading mb-10 text-ink">Ready to get started?</h2>
          <div class="max-w-[75ch] divide-y divide-ink-divider">
            <div class="pb-8">
              <p class="ts-body-large mb-4 text-ink-secondary">Have an idea and ready to build?</p>
              <Button href="/project-application-form" variant="primary" size="md" arrow>
                Apply to the incubator
              </Button>
            </div>
            <div class="py-8">
              <p class="ts-body-large mb-4 text-ink-secondary">
                Want to lead a project but need inspiration?
              </p>
              <Button href="/ideas-new" variant="ghost" size="md" arrow>
                Browse project ideas
              </Button>
            </div>
            <div class="pt-8">
              <p class="ts-body-large mb-4 text-ink-secondary">
                Want to contribute your skills to existing projects?
              </p>
              <Button href="/volunteer-new" variant="ghost" size="md" arrow>
                Register as a volunteer
              </Button>
            </div>
          </div>
          <p class="ts-body mt-10 text-ink-secondary">
            If you have already applied, we'll reach out to you soon.
          </p>
        </div>
      </div>
    </section>

    <!-- Sign-up form -->
    <section class="bg-sand px-6 py-14 min-[810px]:px-10 min-[810px]:py-20">
      <div class="mx-auto max-w-screen-md">
        <SignUpForm />
      </div>
    </section>
  </main>
</HomeLayout>

<style>
  .incubator-animate {
    opacity: 0;
    transform: translateY(12px);
  }
  .incubator-animate.visible {
    animation: fadeUp 0.6s cubic-bezier(0.25, 1, 0.5, 1) both;
  }
  :global(html.no-js) .incubator-animate {
    opacity: 1;
    transform: none;
  }
  @media (prefers-reduced-motion: reduce) {
    .incubator-animate {
      opacity: 1;
      transform: none;
    }
    .incubator-animate.visible {
      animation: none;
    }
  }
</style>

<script>
  const sections = document.querySelectorAll<HTMLElement>(".incubator-animate");
  if (sections.length > 0 && !window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("visible");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.2 }
    );
    sections.forEach((el) => observer.observe(el));
  } else {
    sections.forEach((el) => {
      el.classList.add("visible");
    });
  }
</script>
