---
import Socials from "./Socials.astro";
import TFPLogo from "./TFPLogo.astro";
import { Icon } from "astro-icon/components";
import NavBar from "./NavBar.svelte";

const currentRoute = Astro.url.pathname;

const navigation: Map<string, { href: string; submenu: [string, string][] | null }> = new Map([
  [
    "Home",
    {
      href: "/",
      submenu: null,
    },
  ],
  [
    "About",
    {
      href: "/about",
      submenu: [
        ["Our Organization", "/about"],
        ["Team", "/team"],
        ["FAQ", "/faq"],
        ["Contact Us", "/contact"],
      ] as [string, string][],
    },
  ],
  [
    "Incubator",
    {
      href: "/incubator",
      submenu: [
        ["Overview", "/incubator"],
        ["Projects", "/projects"],
        ["Ideas", "/ideas"],
        ["Tools", "/tools"],
      ] as [string, string][],
    },
  ],
  [
    "Get Involved",
    {
      href: "/get-involved",
      submenu: [
        ["Become a Member", "/membership"],
        ["Donate", "/donate"],
        ["Join the Incubator", "https://techforpalestine.org/project-application-form"],
        ["Volunteer", "/volunteer"],
        ["Entrepreneurs for Palestine", "/e4p"],
        ["Be a Mentor", "/mentorship"],
        ["Hire Palestinians", "/help/hire"],
        ["Join our Discord", "https://techforpalestine.org/discord-invite"],
      ] as [string, string][],
    },
  ],
  [
    "Events",
    {
      href: "/events",
      submenu: [
        ["Past Events", "/events"],
        ["Brussels 2026", "https://brussels2026.techforpalestine.org/"],
        ["Barcelona 2026", "https://barcelona2026.techforpalestine.org/"],
        ["Bay Area 2026", "https://summit.techforpalestine.org"],
        ["London 2025", "/london-gathering"],
      ] as [string, string][],
    },
  ],
  [
    "Updates",
    {
      href: "https://updates.techforpalestine.org",
      submenu: null,
    },
  ],
]);

// TODO: MOVE BANNER TO LAYOUT
---

<NavBar client:load navigation={navigation} currentRoute={currentRoute}>
  <TFPLogo slot="tfp-logo" />
  <Socials slot="socials" />
  <Icon name="solar:hamburger-menu-outline" class="h-8 w-8" slot="burger-icon" />
  <Icon name="mdi:close" class="h-8 w-8" slot="close" />
</NavBar>
