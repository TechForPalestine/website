---
import Section from "./Section.astro";

const testimonials = [
  {
    quote:
      "Being part of T4P has been one of the most meaningful experiences of my career. The community is genuine and the impact is real.",
    name: "Sarah K.",
    role: "Software Engineer, Boycat",
  },
  {
    quote:
      "T4P connected us with mentors who had exactly the experience we needed. Within weeks we had a clear path forward.",
    name: "Omar R.",
    role: "Founder, Newscord",
  },
  {
    quote:
      "The volunteers we found through T4P became core team members. That network is unlike anything else.",
    name: "Lina M.",
    role: "Product Lead, Find a Protest",
  },
];
---

<Section id="testimonials" class="bg-page">
  <div class="mb-12">
    <p class="ts-eyebrow mb-3 text-brand">From the people building with us</p>
    <h2 class="ts-heading mb-2 text-ink">What it's like to work with T4P</h2>
    <p class="ts-body-large text-ink-secondary">
      Project leaders, mentors, and members on their time inside the coalition.
    </p>
  </div>

  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {testimonials.map((t) => (
      <div class="flex flex-col gap-5 rounded-md bg-cream p-6 md:p-8">
        <p class="ts-quote text-ink flex-grow">"{t.quote}"</p>
        <div class="flex items-center gap-3 border-t border-ink-divider pt-5">
          <!-- Avatar placeholder -->
          <div class="h-9 w-9 shrink-0 rounded-pill bg-ink-divider" aria-hidden="true"></div>
          <div>
            <p class="ts-label text-ink">{t.name}</p>
            <p class="ts-caption text-ink-secondary">{t.role}</p>
          </div>
        </div>
      </div>
    ))}
  </div>
</Section>
