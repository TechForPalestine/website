---
interface Props {
  membershipLive?: boolean;
}

const { membershipLive = false } = Astro.props;
const volunteerTitle = membershipLive ? "Member" : "Volunteer";

const testimonials = [
  {
    quote:
      "The valuable advice and launch support from T4P was exactly what we needed to finally hit cash-flow positive and build our impact.",
    name: "Hani & Said Chihabi",
    role: "Founders, Thaura",
    logo: "/thaura.svg",
    headshots: [
      "/images/new-homepage/testimonials/hani.webp",
      "/images/new-homepage/testimonials/said.webp",
    ],
  },
  {
    quote:
      "Tech for Palestine has been a true partner to UpScrolled from the early days, opening doors to their ecosystem and standing by us at every step of the journey.",
    name: "Issam Hijazi",
    role: "Founder, UpScrolled",
    logo: "/upscrolled-icon.svg",
    headshot: "/images/new-homepage/testimonials/issam-hijazi.webp",
  },
  {
    quote:
      "With the volunteers and partnerships provided, we went from a minimally viable concept to a full-fledged global platform reaching millions of accounts each month.",
    name: "Nima Akram",
    role: "Founder, Newscord",
    logo: "/newscord.svg",
    headshot: "/images/new-homepage/testimonials/newscord.webp",
  },
  {
    quote:
      "T4P isn't just a projects incubator, it incubated me too. As someone from Gaza, being part of a team that actively supports and advocates for Palestine makes this work feel deeply personal.",
    name: "Mohanad",
    role: `${volunteerTitle}, Tech for Palestine`,
    headshot: "/images/new-homepage/testimonials/anonymous.svg",
  },
  {
    quote:
      "Being part of Tech for Palestine is not a duty, it is a privilege. This is work we do to help forge a future for everyone who is being oppressed.",
    name: "Veda",
    role: `${volunteerTitle}, Tech for Palestine`,
    headshot: "/images/new-homepage/testimonials/anonymous.svg",
  },
  {
    quote:
      "T4P gave me a meaningful way to support the Palestinian cause and liberation. It is inspiring to connect with T4P's deeply committed people and volunteers, all united in driving positive change, through the high-impact projects we support.",
    name: "Cecile",
    role: `${volunteerTitle}, Tech for Palestine`,
    headshot: "/images/new-homepage/testimonials/anonymous.svg",
  },
];
---

<section class="bg-page pb-14 pt-14 min-[810px]:pb-20 min-[810px]:pt-20">
  <div class="mx-auto max-w-[1400px] px-6 min-[810px]:px-10">
    <div
      class="testimonials-header mb-12 grid grid-cols-1 gap-6 min-[810px]:mb-16 min-[810px]:grid-cols-[1fr_1fr] min-[810px]:items-end"
    >
      <div>
        <p class="ts-overline mb-8 text-ink-secondary">From the people building with us</p>
        <h2 class="ts-editorial leading-[1.2] text-ink">
          What it's like to <span class="text-brand">work with T4P</span>
        </h2>
      </div>
      <p
        class="ts-body text-ink-secondary min-[810px]:ml-auto min-[810px]:max-w-[400px] min-[810px]:text-right"
      >
        Project leaders, mentors, and members on their time inside the coalition.
      </p>
    </div>

    <div class="mb-12 border-t border-ink-divider min-[810px]:mb-16"></div>

    <div
      class="testimonials-marquee -mx-6 overflow-hidden min-[810px]:-mx-10"
      aria-label="Testimonials carousel"
    >
      <div class="marquee-track flex w-max gap-4 will-change-transform min-[810px]:gap-6">
        {
          [...testimonials, ...testimonials, ...testimonials].map((t, i) => (
            <div
              class:list={[
                "testimonial-card flex min-w-[300px] max-w-[300px] shrink-0 flex-col rounded-[20px] border border-butter bg-sand p-6 min-[810px]:min-w-[420px] min-[810px]:max-w-[420px] min-[810px]:p-8",
                i >= testimonials.length && "marquee-dupe",
              ]}
            >
              <svg
                class="mb-6 shrink-0 text-brand"
                width="32"
                height="32"
                viewBox="0 0 24 24"
                fill="currentColor"
                aria-hidden="true"
              >
                <path d="M4.583 17.321C3.553 16.227 3 15 3 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179zm10 0C13.553 16.227 13 15 13 13.011c0-3.5 2.457-6.637 6.03-8.188l.893 1.378c-3.335 1.804-3.987 4.145-4.247 5.621.537-.278 1.24-.375 1.929-.311 1.804.167 3.226 1.648 3.226 3.489a3.5 3.5 0 01-3.5 3.5c-1.073 0-2.099-.49-2.748-1.179z" />
              </svg>
              <p class="ts-quote flex-1 text-ink">{t.quote}</p>
              <footer class="mt-8 flex items-center gap-3">
                {t.headshots ? (
                  <div class="relative h-12 w-12 shrink-0">
                    <img
                      src={t.headshots[0]}
                      alt=""
                      width="36"
                      height="36"
                      loading="lazy"
                      decoding="async"
                      class="testimonial-avatar absolute -left-2 top-0 z-10 h-8 w-8 rounded-full object-cover"
                    />
                    <img
                      src={t.headshots[1]}
                      alt=""
                      width="36"
                      height="36"
                      loading="lazy"
                      decoding="async"
                      class="testimonial-avatar absolute bottom-0 right-0 h-8 w-8 rounded-full object-cover"
                    />
                  </div>
                ) : (
                  <img
                    src={t.headshot}
                    alt=""
                    width="48"
                    height="48"
                    loading="lazy"
                    decoding="async"
                    class="testimonial-avatar h-12 w-12 rounded-full object-cover"
                  />
                )}
                <div>
                  <p class="ts-label text-ink">{t.name}</p>
                  <p class="ts-body-small mt-0.5 text-ink-secondary">{t.role}</p>
                </div>
              </footer>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .testimonial-avatar {
    box-shadow: 0 0 0 1px var(--color-ink-ring);
  }

  /* Header entrance */
  .testimonials-header {
    opacity: 0;
    translate: 0 24px;
    transition:
      opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1),
      translate 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .testimonials-header.in-view {
    opacity: 1;
    translate: none;
  }

  /* Card hover */
  .testimonial-card {
    transition: background-color 0.2s ease;
  }
  .testimonial-card:hover {
    background-color: var(--color-butter);
  }

  :global(html.no-js) .testimonials-header {
    opacity: 1;
    translate: none;
  }
  :global(html.no-js) .marquee-dupe {
    display: none;
  }
  :global(html.no-js) .testimonials-marquee {
    overflow: visible;
    margin: 0;
  }
  :global(html.no-js) .marquee-track {
    width: 100%;
    flex-wrap: wrap;
    gap: 1.5rem;
    justify-content: center;
  }
  :global(html.no-js) .testimonial-card {
    flex: 1 1 300px;
  }

  @keyframes marquee-scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-33.333%);
    }
  }

  .marquee-track {
    animation: marquee-scroll 40s linear infinite;
  }

  .testimonials-marquee:hover .marquee-track {
    animation-play-state: paused;
  }

  @media (prefers-reduced-motion: reduce) {
    .testimonials-header {
      opacity: 1;
      translate: none;
      transition: none;
    }
    .marquee-dupe {
      display: none;
    }
    .testimonials-marquee {
      overflow: visible;
      margin: 0;
    }
    .marquee-track {
      width: 100%;
      flex-wrap: wrap;
      gap: 1.5rem;
      justify-content: center;
      animation: none;
    }
    .testimonial-card {
      flex: 1 1 300px;
    }
  }
</style>

<script>
  const testimonialsHeaderObs = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("in-view");
          testimonialsHeaderObs.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.15 }
  );

  document
    .querySelectorAll<HTMLElement>(".testimonials-header")
    .forEach((el) => testimonialsHeaderObs.observe(el));
</script>
