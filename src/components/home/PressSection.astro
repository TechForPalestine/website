---
import Section from "./Section.astro";
import Button from "../ui/Button.astro";

const articles = [
  {
    publication: "The Guardian",
    date: "Feb 2026",
    headline:
      "How a Discord server became an 80-project incubator for Palestinian liberation",
    href: "#",
  },
  {
    publication: "The Guardian",
    date: "Feb 2026",
    headline:
      "How a Discord server became an 80-project incubator for Palestinian liberation",
    href: "#",
  },
  {
    publication: "The Guardian",
    date: "Feb 2026",
    headline:
      "How a Discord server became an 80-project incubator for Palestinian liberation",
    href: "#",
  },
];
---

<Section id="press" class="bg-page">
  <div class="mb-10">
    <p class="ts-eyebrow mb-3 text-brand">In the press</p>
    <h2 class="ts-heading text-ink">Making headlines</h2>
  </div>

  <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    {articles.map((a) => (
      <article class="flex flex-col gap-4 rounded-md bg-cream p-6">
        <!-- Publication image placeholder -->
        <div class="h-10 w-32 rounded-sm bg-ink-divider" aria-hidden="true"></div>
        <div class="flex flex-col gap-2 flex-grow">
          <p class="ts-caption text-ink-muted">{a.publication} · {a.date}</p>
          <p class="ts-body text-ink">{a.headline}</p>
        </div>
        <Button href={a.href} variant="text" arrow>Read article</Button>
      </article>
    ))}
  </div>
</Section>
