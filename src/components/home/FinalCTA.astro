---
import Section from "./Section.astro";
import Button from "../ui/Button.astro";
---

<Section class="bg-ink">
  <div class="max-w-2xl">
    <h2 class="ts-heading mb-4 text-page">
      You've seen what we've built.<br />Now build with us.
    </h2>
    <p class="ts-body-large mb-10 text-page/70">
      By joining you'll get access to our private member Hub, where you can volunteer your
      skills, connect with the community and receive advanced updates.
    </p>

    <div class="flex flex-wrap items-center gap-4 mb-12">
      <Button href="/get-involved" variant="primary" arrow>Become a member</Button>
    </div>

    <div class="border-t border-page/20 pt-10">
      <p class="ts-body-small mb-5 text-page/60">Can't join right now?</p>
      <p class="ts-label mb-6 text-page">Donate to keep it running</p>
      <div class="flex flex-wrap gap-3">
        {["$25", "$50", "$100", "Custom"].map((amount) => (
          <a
            href="/donate"
            class="ts-label rounded-pill border border-page/30 px-5 py-3 text-page transition hover:border-page/60 hover:bg-page/10"
          >
            {amount}
          </a>
        ))}
      </div>
      <p class="ts-caption mt-6 text-page/40">
        T4P is a 501(c)(3) — donations are tax deductible in the US.{" "}
        <a href="/donate#uk" class="underline hover:text-page/60">
          Click here to donate in the UK with Gift Aid.
        </a>
      </p>
    </div>
  </div>
</Section>
