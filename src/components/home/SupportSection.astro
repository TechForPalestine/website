---
const items = [
  {
    number: "01",
    heading: "Mentorship",
    body: "Strategy sessions and optional weekly office hours. Real guidance from people who've built, shipped, and scaled before.",
    label: "30+ expert mentors · async + live",
  },
  {
    number: "02",
    heading: "Community",
    body: "Access to a global network of skilled members: engineers, marketers, designers and more, with a dedicated recruitment team to match you to the people you need. Connections to NGOs, advocacy groups, civil society organizations, influencers, and funders.",
    label: "400+ global volunteers",
  },
  {
    number: "03",
    heading: "Operations",
    body: "Engineering expertise, security support, marketing campaigns and early users through press, influencers, ecosystem partners, and the T4P community. We help projects reach the people who need them.",
    label: "Tailored for your needs",
  },
  {
    number: "04",
    heading: "Funding",
    body: "Small grants for most accepted projects. Simple process, no strings attached. We fund what works, not what looks good on a deck.",
    label: "Rolling basis",
  },
];
---

<section class="bg-page px-6 pb-14 pt-14 min-[810px]:px-10 min-[810px]:pb-20 min-[810px]:pt-20">
  <div class="mx-auto max-w-[1400px]">
    <p class="ts-overline mb-10 text-ink-secondary">Our support</p>

    <h2 class="ts-editorial pb-6 text-ink">
      How do we enable projects to <span class="text-brand">succeed?</span>
    </h2>
    <p class="ts-body-large max-w-[52ch] pb-10 text-ink-secondary min-[810px]:pb-14">
      We give teams and projects the support they need to ship, scale, and make an impact.
    </p>

    <div class="mb-14 h-px w-full bg-ink-divider min-[810px]:mb-16"></div>

    <div class="support-photo mb-16 overflow-hidden rounded-2xl min-[810px]:mb-24">
      <img
        src="/images/new-homepage/support/team.webp"
        alt="Tech for Palestine community gathered at the Barcelona conference, April 2026"
        width="1600"
        height="1067"
        loading="lazy"
        decoding="async"
        class="animate-ken-burns h-[480px] w-full object-cover object-center motion-reduce:animate-none md:h-[560px]"
      />
    </div>

    <ul class="list-none p-0" role="list">
      {
        items.map((item, i) => (
          <li
            class="support-item rounded-[20px] bg-sand px-8 py-10 min-[810px]:grid min-[810px]:grid-cols-[4.5rem_1fr] min-[810px]:gap-x-6 min-[810px]:px-12 min-[810px]:py-12"
            data-i={i}
          >
            <span class="ts-body-large mb-3 block text-ink-secondary min-[810px]:mb-0 min-[810px]:pt-1">
              {item.number}
            </span>
            <div>
              <h3 class="ts-subheading text-ink">{item.heading}</h3>
              <p class="ts-body mt-4 max-w-[52ch] text-ink-secondary">{item.body}</p>
              <p class="ts-label mt-6 text-brand">{item.label}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .support-photo {
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.8s cubic-bezier(0.25, 1, 0.5, 1),
      transform 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }
  .support-photo.in-view {
    opacity: 1;
    transform: translateY(0);
  }

  .support-item {
    opacity: 0;
    transform: translateY(40px) scale(0.97);
    transition:
      opacity 0.7s cubic-bezier(0.25, 1, 0.5, 1),
      transform 0.7s cubic-bezier(0.25, 1, 0.5, 1),
      background-color 0.2s ease;
    margin-bottom: 12px;
  }
  .support-item.in-view {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
  @media (hover: hover) and (min-width: 810px) {
    .support-item:hover {
      background-color: var(--color-butter);
      transform: translateX(8px);
    }
    .support-item.in-view:hover {
      transform: translateX(8px);
    }
  }

  :global(html.no-js) .support-photo,
  :global(html.no-js) .support-item {
    opacity: 1;
    transform: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .support-photo,
    .support-item {
      opacity: 1;
      transform: none;
      transition: background-color 0.2s ease;
    }
    .support-item:hover,
    .support-item.in-view:hover {
      transform: none;
    }
  }
</style>

<script>
  const photo = document.querySelector<HTMLElement>(".support-photo");
  if (photo) {
    const photoObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            photoObserver.disconnect();
          }
        });
      },
      { threshold: 0.1 }
    );
    photoObserver.observe(photo);
  }

  const supportItems = Array.from(document.querySelectorAll<HTMLElement>(".support-item"));
  if (supportItems.length) {
    const itemObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("in-view");
            itemObserver.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.1 }
    );
    supportItems.forEach((item, i) => {
      item.style.transitionDelay = `${i * 0.12}s`;
      itemObserver.observe(item);
    });
  }
</script>
