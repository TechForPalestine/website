---
import Section from "./Section.astro";
---

<Section class="bg-butter">
  <div class="max-w-3xl">
    <p class="ts-eyebrow mb-8 text-brand">Why T4P exists</p>
    <blockquote class="mb-8">
      <p class="ts-quote text-ink">
        "Tens of thousands of well-funded hasbara projects exist. We're building tens of
        thousands of liberation initiatives to match them."
      </p>
    </blockquote>
    <footer class="flex items-center gap-4">
      <!-- Avatar placeholder -->
      <div class="h-10 w-10 rounded-pill bg-ink-divider" aria-hidden="true"></div>
      <div>
        <p class="ts-label text-ink">Paul Biggar</p>
        <p class="ts-body-small text-ink-secondary">Founder, Tech for Palestine</p>
      </div>
    </footer>
  </div>
</Section>
