---
const LOGO_DEFAULTS = {
  bg: "bg-white",
  padding: "p-8 md:p-4 lg:p-8",
  imgClass: "max-h-[170px] w-full max-w-[340px] object-contain",
};

const projects = [
  {
    name: "UpScrolled",
    description:
      "The social platform with no shadowbans and no algorithmic games. Every voice gets equal reach. Launched and scaled via the T4P incubator and ecosystem partners.",
    logo: { src: "/images/new-homepage/proj-logo-5.webp", alt: "UpScrolled logo" },
    stats: [
      { label: "Global App Store", value: "#1" },
      { label: "Users in 7 months", value: "5M+" },
    ],
  },
  {
    name: "Boycat",
    description:
      "Scan any product to check its ethical compliance and find alternatives in real time. Official BDS partner app, connected through T4P.",
    logo: { src: "/images/new-homepage/proj-logo-3.webp", alt: "Boycat logo" },
    stats: [
      { label: "Users worldwide", value: "3M+" },
      { label: "Redirected to ethical brands", value: "$500M+" },
    ],
  },
  {
    name: "Thaura.ai",
    description:
      "AI built ethically, designed around environmental, social, and privacy concerns. Launched via the T4P network to profitability.",
    logo: { src: "/images/new-homepage/proj-logo-4.webp", alt: "Thaura.ai logo" },
    stats: [
      { label: "Less energy than ChatGPT", value: "94%" },
      { label: "Data sold to third parties", value: "0" },
    ],
  },
  {
    name: "Apricot",
    description:
      "Connecting top tech talent from the Middle East, including Palestinian refugees, with US tech companies. Customer introductions and strategic refocus via T4P.",
    logo: { src: "/images/new-homepage/proj-logo-2.webp", alt: "Apricot logo" },
    stats: [
      { label: "Paid to placed talent", value: "$1M" },
      { label: "Candidates", value: "10k+" },
    ],
  },
  {
    name: "Newscord",
    description:
      "AI-powered news summaries across hundreds of sources, exposing media bias in every language. Refocused and connected with T4P ecosystem partners.",
    logo: {
      src: "/images/new-homepage/proj-logo-1.webp",
      alt: "Newscord logo",
      bg: "bg-black",
      padding: "px-14 py-0",
      imgClass: "max-h-[170px] w-[180px] max-w-full object-contain",
    },
    stats: [{ label: "Accounts reached monthly", value: "10M+" }],
  },
  {
    name: "Find a Protest",
    description:
      "Find and subscribe to protests in your area, powered by organizers, communities, and volunteer data collectors. Refocused and volunteer-powered through T4P.",
    logo: {
      src: "/images/new-homepage/proj-logo-findaprotest.webp",
      alt: "Find a Protest logo",
      imgClass: "max-h-[120px] w-full max-w-[220px] object-contain",
    },
    stats: [
      { label: "Monthly users", value: "200k+" },
      { label: "Protests & solidarity events listed", value: "10k+" },
    ],
  },
];
---

<section id="portfolio" class="bg-page px-6 pt-24 pb-24 md:px-10 md:pt-32 md:pb-32">
  <div class="mx-auto max-w-[1400px]">
    <p class="ts-eyebrow mb-10 text-ink-secondary">— Our portfolio</p>

    <div class="grid grid-cols-1 gap-8 pb-10 md:grid-cols-2 md:gap-16 md:pb-14">
      <h2 class="ts-editorial text-ink">
        Projects that came through <span class="text-brand">T4P</span>
      </h2>
      <div>
        <p class="ts-body-large text-ink-secondary">
          Every one of these projects was scaled through T4P. Powered by volunteers, mentors, and people like you.
        </p>
      </div>
    </div>

    <div class="mb-6 h-px w-full bg-ink-divider md:mb-8"></div>
  </div>

  <div class="mx-auto max-w-[1400px]">
  <ul class="portfolio-stack list-none p-0">
      {projects.map((p, i) => (
        <li
          class="portfolio-card-wrap"
          data-i={i}
        >
          <article class="portfolio-card grid w-full grid-cols-1 gap-8 rounded-[20px] border border-butter bg-sand p-6 md:grid-cols-[1.2fr_1fr] md:items-center md:gap-10 md:p-10 lg:grid-cols-2 lg:gap-12 lg:p-14">
            <div class="flex flex-col">
              <h3 class="ts-editorial text-ink">{p.name}</h3>
              <p class="ts-body mt-5 text-ink-secondary">
                {p.description}
              </p>
              <dl class="mt-10 flex flex-col gap-y-6 lg:mt-auto lg:flex-row lg:gap-x-10 lg:pt-12">
                {p.stats.map((s) => (
                  <div>
                    <dt class="ts-body-large text-ink-secondary">{s.label}</dt>
                    <dd class="ts-stat-large mt-2 text-brand">
                      {s.value}
                    </dd>
                  </div>
                ))}
              </dl>
            </div>

            <div class="logo-frame relative w-full md:h-[190px]">
              <div class="logo-frame-back" aria-hidden="true"></div>
              <div class:list={["logo-frame-front relative flex items-center justify-center rounded-[16px] w-full h-full", p.logo.padding ?? LOGO_DEFAULTS.padding, p.logo.bg ?? LOGO_DEFAULTS.bg]}>
              <img
                src={p.logo.src}
                alt={p.logo.alt}
                loading="lazy"
                width="340"
                height="170"
                sizes="(max-width: 768px) 280px, 340px"
                class={p.logo.imgClass ?? LOGO_DEFAULTS.imgClass}
              />
              </div>
            </div>
          </article>
        </li>
      ))}
  </ul>
  </div>
</section>

<style>
  .portfolio-stack {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .portfolio-card {
    transition: transform 0.35s ease;
  }

  .logo-frame-back {
    position: absolute;
    inset: 0;
    border-radius: 16px;
    background: #EFE3D4;
    transform: rotate(-3deg);
    box-shadow: 0 6px 20px rgba(0, 0, 0, 0.06);
  }
  .logo-frame-front {
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08), 0 2px 6px rgba(0, 0, 0, 0.05);
  }

  .portfolio-card-wrap {
    opacity: 0;
    transform: translateY(32px);
    width: 100%;
  }
  .portfolio-card-wrap.in-view {
    opacity: 1;
    transform: translateY(0);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
  }

  @media (min-width: 768px) {
    .portfolio-card-wrap {
      position: sticky;
      transform-origin: top center;
      opacity: 0;
      transition: transform 0.35s ease, opacity 0.7s ease-out;
      will-change: transform;
    }
    .portfolio-card-wrap.in-view { opacity: 1; }
    .portfolio-card-wrap[data-i="0"] { top: 40px; }
    .portfolio-card-wrap[data-i="1"] { top: 64px; }
    .portfolio-card-wrap[data-i="2"] { top: 88px; }
    .portfolio-card-wrap[data-i="3"] { top: 112px; }
    .portfolio-card-wrap[data-i="4"] { top: 136px; }
    .portfolio-card-wrap[data-i="5"] { top: 160px; }
  }

  @media (prefers-reduced-motion: reduce) {
    .portfolio-card-wrap {
      position: static;
      opacity: 1;
      transform: none;
    }
    .portfolio-card { transition: none; }
  }
</style>

<script>
  const cards = Array.from(
    document.querySelectorAll<HTMLElement>(".portfolio-card-wrap")
  );

  if (cards.length) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            (entry.target as HTMLElement).classList.add("in-view");
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.15 }
    );
    cards.forEach((card, i) => {
      card.style.transitionDelay = `${i * 0.1}s`;
      observer.observe(card);
    });

    const prefersReducedMotion = window.matchMedia(
      "(prefers-reduced-motion: reduce)"
    ).matches;
    const isDesktop = window.matchMedia("(min-width: 768px)").matches;

    if (!prefersReducedMotion && isDesktop) {
      const SCALE_STEP = 0.025;
      const MIN_SCALE = 0.88;

      const updateStackScales = () => {
        // Find the index of the bottom-most card that has reached its sticky top.
        let activeIdx = -1;
        cards.forEach((card, i) => {
          const rect = card.getBoundingClientRect();
          const stickyTop = parseFloat(getComputedStyle(card).top);
          if (rect.top <= stickyTop + 0.5) activeIdx = i;
        });

        cards.forEach((card, i) => {
          const depth = activeIdx - i;
          const scale =
            depth > 0 ? Math.max(MIN_SCALE, 1 - depth * SCALE_STEP) : 1;
          card.style.transform = `scale(${scale})`;
        });
      };

      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          updateStackScales();
          ticking = false;
        });
      };

      window.addEventListener("scroll", onScroll, { passive: true });
      window.addEventListener("resize", onScroll, { passive: true });
      updateStackScales();
    }
  }
</script>
