---
import Button from "../ui/Button.astro";
---

<section class="px-4 pt-4 pb-0 sm:px-6 sm:py-6">
  <div class="relative overflow-hidden rounded-3xl">
    <!-- Background image -->
    <img
      src="/images/new-homepage/hero.png"
      alt="Palestinian children playing near the separation wall"
      class="h-[calc(100svh-2rem)] min-h-[500px] w-full object-cover object-center animate-ken-burns motion-reduce:animate-none sm:h-[calc(100svh-3rem)]"
    />

    <!-- Mobile overlay (below 800px): logo + scroll down -->
    <div class="absolute inset-0 flex flex-col items-center pt-16 min-[800px]:hidden">
      <div class="hero-logo">
        <img src="/images/new-homepage/t4p-logo.webp" alt="Tech for Palestine" class="h-[8.2rem]" />
      </div>
      <a href="#mobile-content" class="hero-cta-a ts-label text-brand flex items-center">
        Scroll down
      </a>
    </div>

    <!-- Desktop overlay (800px+): full hero card -->
    <div class="absolute inset-0 hidden items-center justify-center min-[800px]:flex">
      <div class="hero-card mx-auto w-[90%] max-w-[1008px] rounded-3xl bg-[#ffffffa3] px-3 py-4 md:px-5 md:py-6">
        <!-- Logo: top-left below 1200px, bottom-right at 1200px+ -->
        <div class="hero-logo mb-4 min-[1200px]:hidden">
          <img src="/images/new-homepage/t4p-logo.webp" alt="Tech for Palestine" class="h-[3.5rem]" />
        </div>

        <h1 class="ts-display mb-7 text-left text-ink tracking-wide">
          <span class="hero-h1-a inline">Join the movement behind 90+ projects for </span><span class="hero-h1-b inline text-brand">Palestinian liberation</span>
        </h1>
        <div class="flex flex-wrap items-center justify-start gap-5 min-[1200px]:justify-between">
          <div class="flex flex-wrap items-center">
            <div class="hero-cta-a">
              <Button href="/get-involved" variant="primary" class="!px-11 !py-5 !text-[16px]">Become a member</Button>
            </div>
            <div class="hero-cta-b">
              <Button href="#portfolio" variant="ghost" class="!border-transparent hover:!bg-transparent">
                See what we've built
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
                  <path d="M12 5v14M5 13l7 7 7-7" />
                </svg>
              </Button>
            </div>
          </div>
          <div class="hero-logo hidden items-center gap-2 min-[1200px]:flex">
            <img src="/images/new-homepage/t4p-logo.webp" alt="Tech for Palestine" class="h-[3.5rem]" />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile content below hero (below 800px) -->
  <div id="mobile-content" class="pt-[160px] min-[800px]:hidden">
    <h1 class="ts-display hero-h1-a mb-8 text-left text-ink">
      Join the movement behind 90+ projects for Palestinian liberation
    </h1>
    <div class="flex flex-col items-start gap-4">
      <div class="hero-cta-a">
        <Button href="/get-involved" variant="primary" arrow class="!px-10 !py-5 !text-[16px]">Become a member</Button>
      </div>
      <div class="hero-cta-b">
        <Button href="#portfolio" variant="ghost" class="!border-transparent hover:!bg-transparent">
          See what we've built
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" aria-hidden="true">
            <path d="M12 5v14M5 13l7 7 7-7" />
          </svg>
        </Button>
      </div>
    </div>
  </div>
</section>
