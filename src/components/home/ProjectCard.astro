---
interface Stat {
  value: string;
  label: string;
}
interface Props {
  name: string;
  description: string;
  stats: Stat[];
}
const { name, description, stats } = Astro.props;
---

<article class="flex flex-col gap-5 rounded-md bg-cream p-6 md:p-8">
  <!-- Logo placeholder -->
  <div class="h-12 w-24 rounded-sm bg-ink-divider" aria-hidden="true"></div>

  <div class="flex flex-col gap-3">
    <h3 class="ts-subheading text-ink">{name}</h3>
    <p class="ts-body text-ink-secondary">{description}</p>
  </div>

  <div class="mt-auto flex flex-wrap gap-6 border-t border-ink-divider pt-5">
    {stats.map((s) => (
      <div class="flex flex-col gap-0.5">
        <span class="ts-stat text-ink">{s.value}</span>
        <span class="ts-caption text-ink-secondary">{s.label}</span>
      </div>
    ))}
  </div>
</article>
